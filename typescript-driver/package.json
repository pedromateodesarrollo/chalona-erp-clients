{
  "name": "@chalona/typescript-driver",
  "version": "0.1.0",
  "description": "Cliente TypeScript para e-CF con hot-reload de driver via Postgres (espejo de dart-driver y csharp-driver)",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
